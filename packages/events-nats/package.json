{
  "name": "@connectum/events-nats",
  "version": "1.0.0-rc.7",
  "description": "NATS JetStream adapter for @connectum/events",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Connectum-Framework/connectum.git",
    "directory": "packages/events-nats"
  },
  "scripts": {
    "dev": "node --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "exodus-test --typescript tests/**/*.test.ts",
    "test:unit": "exodus-test --typescript tests/unit/**/*.test.ts",
    "test:bun": "exodus-test --engine bun:pure tests/unit/**/*.test.ts",
    "test:esbuild": "exodus-test --esbuild tests/unit/**/*.test.ts",
    "lint": "biome check src",
    "format": "biome check --write src",
    "build": "tsup",
    "clean": "rm -rf coverage dist"
  },
  "keywords": [
    "events",
    "nats",
    "jetstream",
    "connectum",
    "adapter"
  ],
  "author": "Highload.Zone",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1"
  },
  "peerDependencies": {
    "@connectum/events": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@connectum/events": {
      "optional": false
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@connectum/events": "workspace:^",
    "c8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
